# Cleanverse sandbox credentials (Service Partner) — copy to .env and fill.
# App ID  -> value of the `api-id` request header (identifies your app; IS sent).
# App Key -> Base64 AES key, used LOCALLY to encrypt request bodies for sensitive
#            Cooperate endpoints. NEVER send it to any server, never commit it.
CLEANVERSE_APP_ID=
CLEANVERSE_APP_KEY=

# API surfaces
CLEANVERSE_COOPERATE_BASE=https://uatapi.cleanverse.com/api/cooperate
CLEANVERSE_SKILLS_BASE=https://uatapi.cleanverse.com/api/skills

# Chain
CHAIN=monad
MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/_ztkT79iUO-dFpkTNDBFB

# Known sandbox addresses (Monad testnet)
APASS_ADDRESS=0xbA82D189540CaC9DC6FF46B6837CaC1BFdEC58B9
AUSDC_ADDRESS=0xaC0893567D43C3E7e6e35a72803df05416C1f20D
USDC_ADDRESS=0x534b2f3A21130d7a60830c2Df862319e593943A3
